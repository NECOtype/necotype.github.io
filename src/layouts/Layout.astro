---
import Head from "../components/Head.astro";

const { title } = Astro.props;
---
<html lang="en">
	<Head>
		<title>{title}</title>
	</Head>
	<body>
		<slot />
	</body>
</html>

<style>
* {
	margin: 0;
	padding: 0;
	box-sizing: border-box;

	--background: #181616;
	--foreground: #c5c9c5;
	--black: #0d0c0c;
	--red: #c4746e;
	--green: #8a9a7b;
	--yellow: #c4b28a;
	--blue: #8ba4b0;
	--magenta: #a292a3;
	--cyan: #8ea4a2;
	--lightwhite: #c5c9c5;
	--hlBackground: #2d4f67;
	--hlForeground: #c8c093;
}

:root {
	--font-head: var(--font-instrument);
	--font-body: var(--font-im-fell);
}

body,
html {
	height: 100%;
	font-family: var(--font-body);
}

body {
	display: grid;
	place-items: center;
	background-color: var(--background);
	color: var(--foreground);
}

</style>